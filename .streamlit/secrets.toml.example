# -------------------------------------------------------------------------
# Streamlit secrets template for visitor tracking.
#
# 1. Copy this file to ".streamlit/secrets.toml" (same folder, drop ".example").
# 2. Fill in the real values (see VISITOR_TRACKING_SETUP.md).
# 3. NEVER commit the real secrets.toml — it is already in .gitignore.
#    On Streamlit Community Cloud, paste these same contents into
#    App settings -> Secrets instead of using a file.
# -------------------------------------------------------------------------

# Password you will type into the in-app "Admin" panel to view visit stats.
admin_password = "change-me"

# Paste the entire service-account JSON here, field by field.
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Keep the literal \n sequences inside the quotes exactly as in the JSON file.
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
client_email = "truss-logger@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/truss-logger%40your-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"

[visitor_log]
# Provide ONE of the following. sheet_key is the long ID in the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_IS_THE_KEY>/edit
sheet_key = "your-google-sheet-key"
# sheet_url = "https://docs.google.com/spreadsheets/d/your-google-sheet-key/edit"
